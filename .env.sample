# =============================================================================
# AI 辩论代理系统环境变量配置模板
# =============================================================================
# 使用说明:
#   1. 复制此文件为 .env:  cp .env.sample .env
#   2. 在 .env 中填入你的真实 API 密钥
#   3. 详细获取说明请参考 .env 文件中的注释
#   4. 切勿将 .env 文件提交到 Git！
# =============================================================================

# =============================================================================
# 1. DeepSeek LLM API (SiliconFlow 平台)
# =============================================================================
CUSTOM_LLM_API_KEY=your_siliconflow_api_key_here
CUSTOM_LLM_API_BASE=https://api.siliconflow.cn/v1
CUSTOM_LLM_MODEL=deepseek-ai/DeepSeek-V3

# =============================================================================
# 2. SiliconFlow Speech API (语音合成)
# =============================================================================
SPEECH_API_KEY=your_siliconflow_api_key_here
SPEECH_API_BASE=https://api.siliconflow.cn/v1
SPEECH_MODEL=FunAudioLLM/CosyVoice2-0.5B
SPEECH_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex

# =============================================================================
# 3. Huawei Cloud AK/SK (备用语音服务)
# =============================================================================
HUAWEI_CLOUD_AK=your_huawei_access_key_here
HUAWEI_CLOUD_SK=your_huawei_secret_key_here

# =============================================================================
# 4. Volcano Engine (火山引擎 - AI 图片生成)
# =============================================================================
VOLCANO_ACCESS_KEY=your_volcano_access_key_here
VOLCANO_SECRET_KEY=your_volcano_secret_key_here

# =============================================================================
# 语音服务通用配置
# =============================================================================
SPEECH_ENABLED=true
SPEECH_API_TYPE=siliconflow
SPEECH_CHUNK_SIZE=100
SPEECH_CACHE_ENABLED=true
SPEECH_SAMPLE_RATE=32000

# =============================================================================
# 智能体角色语音配置
# =============================================================================
SUPPORTER_VOICE=alloy
SUPPORTER_SPEED=1.0
OPPONENT_VOICE=echo
OPPONENT_SPEED=1.0
JUDGE_VOICE=onyx
JUDGE_SPEED=1.0

# =============================================================================
# 服务器配置
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=["*"]

# =============================================================================
# 辩论系统配置
# =============================================================================
DEFAULT_MAX_ROUNDS=10

# =============================================================================
# 5. ModelArts API (新闻生成辩论功能)
# =============================================================================
MODELARTS_API_KEY=your_modelarts_api_key_here

# =============================================================================
# 6. Flask 配置
# =============================================================================
FLASK_DEBUG=false

# =============================================================================
# 调试配置 (可选)
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
